+def _position_market_data(
+    ib: object, positions: Sequence[object], timeout: float
+) -> Dict[Tuple[str, int], Dict[str, Optional[float]]]:
+    """Load read-only portfolio and per-contract P&L data for positions."""
+    accounts = sorted({str(position.account) for position in positions})
+    active_account: Optional[str] = None
+    portfolio_by_key: Dict[Tuple[str, int], object] = {}
+    pnl_by_key: Dict[Tuple[str, int], object] = {}
+    subscriptions: List[Tuple[str, int]] = []
+    try:
+        for account in accounts:
+            active_account = account
+            try:
+                ib.reqAccountUpdates(account)
+                for item in ib.portfolio(account):
+                    contract = item.contract
+                    portfolio_by_key[(str(item.account), int(contract.conId))] = item
+            except TimeoutError:
+                pass
+            finally:
+                _cancel_account_updates(ib, account)
+                active_account = None
+
+        for position in positions:
+            key = (str(position.account), int(position.contract.conId))
+            try:
+                pnl_by_key[key] = ib.reqPnLSingle(position.account, "", position.contract.conId)
+                subscriptions.append(key)
+            except Exception:
+                continue
+        if subscriptions:
+            ib.sleep(min(max(timeout / 2, 0.1), 1.0))
+    finally:
+        for account, con_id in subscriptions:
+            ib.cancelPnLSingle(account, "", con_id)
+        if active_account is not None:
+            _cancel_account_updates(ib, active_account)
+
+    result: Dict[Tuple[str, int], Dict[str, Optional[float]]] = {}
+    for position in positions:
+        key = (str(position.account), int(position.contract.conId))
+        portfolio = portfolio_by_key.get(key)
+        pnl = pnl_by_key.get(key)
+        result[key] = {
+            "market_price": _first_number(getattr(portfolio, "marketPrice", None)),
+            "market_value": _first_number(
+                getattr(pnl, "value", None), getattr(portfolio, "marketValue", None)
+            ),
+            "unrealized_pnl": _first_number(
+                getattr(pnl, "unrealizedPnL", None), getattr(portfolio, "unrealizedPNL", None)
+            ),
+            "realized_pnl": _first_number(
+                getattr(pnl, "realizedPnL", None), getattr(portfolio, "realizedPNL", None)
+            ),
+            "daily_pnl": _first_number(getattr(pnl, "dailyPnL", None)),
+        }
+    return result
