+def _cancel_account_updates(ib: object, account: str) -> None:
+    cancel = getattr(ib, "cancelAccountUpdates", None)
+    if callable(cancel):
+        cancel(account)
+        return
+    client = getattr(ib, "client", None)
+    request = getattr(client, "reqAccountUpdates", None)
+    if callable(request):
+        request(False, account)
