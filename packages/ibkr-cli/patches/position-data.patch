+def _first_number(*values: object) -> Optional[float]:
+    for value in values:
+        normalized = _normalize_number(value)
+        if normalized is not None:
+            return normalized
+    return None
+
+
+CLIENT_ID_MIN = 1
+CLIENT_ID_MAX = 32767
+CLIENT_ID_ATTEMPTS = 5
+
+
+def _is_client_id_collision(value: object) -> bool:
+    if isinstance(value, BaseException):
+        values = [str(value), *(str(arg) for arg in value.args)]
+        cause = value.__cause__ or value.__context__
+        if cause is not None:
+            values.append(str(cause))
+    else:
+        values = [str(value)]
+    text = " ".join(values).lower()
+    return bool(
+        re.search(r"\b326\b", text)
+        or ("client id" in text and "already in use" in text)
+        or ("clientid" in text and "already in use" in text)
+    )
+
+
+def _random_client_id(used: set[int]) -> int:
+    for _ in range(CLIENT_ID_MAX - CLIENT_ID_MIN + 1):
+        candidate = secrets.randbelow(CLIENT_ID_MAX - CLIENT_ID_MIN + 1) + CLIENT_ID_MIN
+        if candidate not in used:
+            return candidate
+    raise RuntimeError("Unable to select a unique IBKR API client ID")
+
+
+def _disconnect_ib(ib: object) -> None:
+    disconnect = getattr(ib, "disconnect", None)
+    if callable(disconnect):
+        try:
+            disconnect()
+        except Exception:
+            logging.getLogger(__name__).debug("Ignoring IBKR disconnect failure", exc_info=True)
+
+
+def _connect_ib(
+    ib_class: object,
+    startup_fetch_none: object,
+    profile: ProfileConfig,
+    timeout: float,
+    readonly: bool,
+) -> object:
+    used: set[int] = set()
+    last_collision: Optional[BaseException] = None
+    for attempt in range(CLIENT_ID_ATTEMPTS):
+        client_id = _random_client_id(used)
+        used.add(client_id)
+        ib = ib_class()
+        setattr(ib, "RequestTimeout", timeout)
+        collision_messages: List[str] = []
+        events: List[object] = []
+
+        def on_ib_error(*messages: object) -> None:
+            if any(_is_client_id_collision(message) for message in messages):
+                collision_messages.append(" ".join(str(message) for message in messages))
+
+        for event in (
+            getattr(ib, "errorEvent", None),
+            getattr(getattr(ib, "client", None), "apiError", None),
+        ):
+            if event is not None and hasattr(event, "connect"):
+                event.connect(on_ib_error)
+                events.append(event)
+        try:
+            with _suppress_ib_async_logs():
+                ib.connect(
+                    profile.host,
+                    profile.port,
+                    clientId=client_id,
+                    timeout=timeout,
+                    readonly=readonly,
+                    fetchFields=startup_fetch_none,
+                )
+            setattr(ib, "_ibkr_cli_client_id", client_id)
+            return ib
+        except BaseException as exc:
+            collision = bool(collision_messages) or _is_client_id_collision(exc)
+            if collision:
+                last_collision = exc
+            else:
+                raise
+        finally:
+            for event in events:
+                if hasattr(event, "disconnect"):
+                    event.disconnect(on_ib_error)
+            if not getattr(ib, "_ibkr_cli_client_id", None):
+                _disconnect_ib(ib)
+
+        if last_collision is None or attempt + 1 >= CLIENT_ID_ATTEMPTS:
+            break
+
+    raise ConnectionError(
+        f"IBKR rejected {CLIENT_ID_ATTEMPTS} unique API client IDs; giving up"
+    ) from last_collision
+
